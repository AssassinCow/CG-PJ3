# Copy this file to .env and fill only the official providers you intend to use.
# Do not commit .env.
#
# Keep values empty until you fill them locally:
#   PROVIDER_API_KEY=

# ---- Official LLM providers ----------------------------------------------

OPENAI_API_KEY=

ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=

GOOGLE_API_KEY=
GEMINI_API_KEY=


# ---- Runtime --------------------------------------------------------------

# Blender executable. Leave empty to use the default executable lookup.
BLENDER_BIN=

# Optional timeout overrides, in seconds.
CG_TUTOR_LLM_TIMEOUT=
CG_TUTOR_API_TIMEOUT=
